# Supabase (use a URL base do projeto, sem /rest/v1/)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron PTAX BCB — protege POST /api/cron/ptax (Supabase pg_cron)
CRON_SECRET= 

# Tenant padrão — apenas scripts locais (seed/repair). O app usa tenant da sessão.
DEFAULT_TENANT_ID=

# Connection string Postgres (opcional — scripts/apply-rls-migration.ts)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[senha]@...pooler.supabase.com:6543/postgres
